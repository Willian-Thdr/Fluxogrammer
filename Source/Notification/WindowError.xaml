<Window x:Class="Fluxogrammer.Source.WindowError"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Fluxogrammer"
        mc:Ignorable="d"
        Title="ERROR" SizeToContent="WidthAndHeight" Background="Black">

        <Border Height="200" Width="400">
            <Canvas>
                <TextBlock x:Name="ShowError" Height="160" Width="360" 
                        Canvas.Top="20" Canvas.Left="20" Background="Black"
                        VerticalAlignment="Center" Foreground="Red" FontSize="16"
                        TextWrapping="Wrap"/>
            </Canvas>
        </Border>
</Window>