<Window x:Class="Fluxogrammer.Source.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Fluxogrammer"
        mc:Ignorable="d"
        Title="MainWindow" Height="720" Width="1080">
    <Grid Width="1080" Height="720">
        <Grid.Background>
            <LinearGradientBrush StartPoint="1,0" EndPoint="0,1">
                <GradientStop Color="#5B1094" Offset="0"/>
                <GradientStop Color="#708AEF" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Canvas>
            <Border Canvas.Top="20" Canvas.Left="440" HorizontalAlignment="Center">
                <Label FontSize="20" Height="34" Width="200" HorizontalAlignment="Center" VerticalAlignment="Center">
                    Teste de menu inicial
                </Label>
            </Border>
        </Canvas>
    </Grid>
</Window>
