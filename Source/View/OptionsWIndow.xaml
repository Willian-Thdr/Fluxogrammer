<Window x:Class="Fluxogrammer.Source.OptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Fluxogrammer.Source"
        mc:Ignorable="d"
        Style="{DynamicResource WindowStyle}"
        Title="Opções" Height="450" Width="600">

        <Window.Resources>
            <local:BindingDivide x:Key="BindingDivide"/>

            <Style x:Key="ToggleStyle" TargetType="ToggleButton">
                <Setter Property="BorderBrush" Value="{DynamicResource Borders}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="border"
                                    Background="Transparent"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="15">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>                            
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- <Style x:Key="ButtonTheme" TargetType="Button">
                <Setter Property="Background" Value="{DynamicResource ButtonsThemeBackground}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ButtonsThemeBorders}"/>
                <Setter Property="Foreground" Value="{DynamicResource ButtonsThemeForeground}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style> -->
        </Window.Resources>

        <Canvas HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <Label Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                HorizontalContentAlignment="Center" FontSize="24pt" Content="Configurações"/>

                <Line X1="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window},
                Converter={StaticResource BindingDivide}, ConverterParameter=2}" 

                Y1="120" 

                X2="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window},
                Converter={StaticResource BindingDivide}, ConverterParameter=2}" 

                Y2="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Window}}" 
                StrokeThickness="2"/>

                <Label Canvas.Left="20" Canvas.Top="170" Content="Tema do programa:"
                FontSize="14pt" Width="175"/>

                <ToggleButton Canvas.Top="170" Canvas.Left="215"
                x:Name="ThemeOptions" Style="{StaticResource ToggleStyle}">
                    <Label Content="Padrão" x:Name="TemaEscolhido" FontSize="14pt"/>
                </ToggleButton>

                <Popup x:Name="PopupTheme"
                    PlacementTarget="{Binding ElementName=ThemeOptions}"
                    Placement="Bottom"
                    IsOpen="{Binding IsChecked, ElementName=ThemeOptions, Mode=TwoWay}"
                    StaysOpen="False"
                    AllowsTransparency="True">

                    <Border Style="{DynamicResource PopupStyle}" BorderThickness="1" Padding="4">
                        <StackPanel>
                            <Button Content="Padrão" Padding="8,4" Click="ThemeButtonClick" Style="{DynamicResource ButtonThemeStyle}"
                            Margin="0,2,0,0"/>
                            <Button Content="Claro" Padding="8,4" Click="ThemeButtonClick" Style="{DynamicResource ButtonThemeStyle}"
                            Margin="0,2,0,2"/>
                            <Button Content="Escuro" Padding="8,4" Click="ThemeButtonClick" Style="{DynamicResource ButtonThemeStyle}"
                            Margin="0,0,0,2"/>
                        </StackPanel>
                    </Border>
                </Popup>
        </Canvas>
</Window>