<Window x:Class="Fluxogrammer.Source.OptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Fluxogrammer.Source"
        mc:Ignorable="d"
        Background="#2b2b2b"
        Title="Opções" Height="450" Width="600">
        <Window.Resources>
            <local:BindingDivide x:Key="BindingDivide"/>

            <Style x:Key="ToggleStyle" TargetType="ToggleButton">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="border"
                                    Background="#20FFFFFF"
                                    BorderBrush="Black"
                                    BorderThickness="1"
                                    CornerRadius="15">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>                            
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Window.Resources>

        <Canvas HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <Label Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                HorizontalContentAlignment="Center" FontSize="24pt" Content="Configurações"/>

                <Line X1="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window},
                Converter={StaticResource BindingDivide}, ConverterParameter=2}" 

                Y1="120" 

                X2="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window},
                Converter={StaticResource BindingDivide}, ConverterParameter=2}" 

                Y2="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Window}}" 
                Stroke="Black" StrokeThickness="2"/>

                <Label Canvas.Left="20" Canvas.Top="170" Content="Tema do programa:"
                FontSize="14pt" Width="175"/>

                <ToggleButton Canvas.Top="170" Canvas.Left="215"
                x:Name="ThemeOptions" Style="{StaticResource ToggleStyle}">
                    <Label Content="Padrão" x:Name="TemaEscolhido" FontSize="14pt"/>
                </ToggleButton>

                <Popup x:Name="PopupTheme"
                    PlacementTarget="{Binding ElementName=ThemeOptions}"
                    Placement="Bottom"
                    IsOpen="{Binding IsChecked, ElementName=ThemeOptions, Mode=TwoWay}"
                    StaysOpen="False"
                    AllowsTransparency="True">

                    <Border Background="White" BorderBrush="Gray" BorderThickness="1" Padding="4">
                        <StackPanel>
                            <Button Content="Escuro" Tag="#2b2b2b" Padding="8,4" Click="ThemeButtonClick"/>
                            <Button Content="Claro" Tag="#ffffff" Padding="8,4" Click="ThemeButtonClick"/>
                            <Button Content="Padrão" Tag="NaN" Padding="8,4" Click="ThemeButtonClick"/>
                        </StackPanel>
                    </Border>
                </Popup>
        </Canvas>
</Window>