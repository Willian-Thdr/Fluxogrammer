<Window x:Class="Fluxogrammer.Source.NewFileOptions"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Fluxogrammer"
        mc:Ignorable="d"
        Title="Novo Fluxograma" Height="450" Width="350">
    <Canvas x:Name="canvasRoot" Background="White">

    <Grid Height="450" Width="350">
        <Grid.Background>
            <LinearGradientBrush StartPoint="1,0" EndPoint="0,1">
                <GradientStop Color="#5B1094" Offset="0"/>
                <GradientStop Color="#708AEF" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Canvas>
            <Label x:Name="LblTest" Content="Criar novo Fluxograma" Canvas.Left="77.5" HorizontalAlignment="Left"
            FontSize="18" Width="195"/>
        </Canvas>
    </Grid>
</Canvas>
</Window>