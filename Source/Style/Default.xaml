<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <LinearGradientBrush x:Key="WindowBackground" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#5b1094" Offset="0"/>
        <GradientStop Color="#708aef" Offset="1"/>
    </LinearGradientBrush>
    
    <SolidColorBrush x:Key="LineColor" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextBrushes" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextBoxBrushes" Color="#000000"/>
    <SolidColorBrush x:Key="Borders" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BackgroundText" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ButtonsBackground" Color="Transparent"/>
    <SolidColorBrush x:Key="ButtonsForeground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BackgroundPopup" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ButtonsThemeBorders" Color="#649eeb"/>
    <SolidColorBrush x:Key="ButtonsThemeBackground" Color="Transparent"/>
    <SolidColorBrush x:Key="ButtonsThemeForeground" Color="#000000"/>
</ResourceDictionary>
